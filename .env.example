# Core
OPENAI_API_KEY=sk-xxx

# Strong dependency checks (set to 1 only in tests)
SCRIPTWRITER_SKIP_DEPENDENCY_CHECK=0

# Knowledge metadata (PostgreSQL)
SCRIPTWRITER_KNOWLEDGE_PG_DSN=postgresql://postgres:password@127.0.0.1:5432/scriptwriter

# Keyword index (OpenSearch / Elasticsearch-compatible)
SCRIPTWRITER_OPENSEARCH_URL=http://127.0.0.1:9200
SCRIPTWRITER_OPENSEARCH_INDEX=knowledge_chunks_v1

# Vector index (Milvus local)
SCRIPTWRITER_MILVUS_DB_PATH=./data/milvus_demo.db

# Retrieval pipeline
SCRIPTWRITER_QUERY_REWRITE_MODEL=gpt-4o-mini
SCRIPTWRITER_RERANK_MODEL=gpt-4o-mini
SCRIPTWRITER_RETRIEVAL_TOPN_VECTOR=12
SCRIPTWRITER_RETRIEVAL_TOPN_KEYWORD=12
SCRIPTWRITER_RETRIEVAL_TOPK_FINAL=5

# Data path for persisted source text
SCRIPTWRITER_RAG_DATA_DIR=data/rag
